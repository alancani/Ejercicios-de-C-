using System;

class Program
{
    static void Main()
    {
        int total = 0;

        for (int i = 1; i <= 7; i++)
        {
            Console.Write("Vacunas del día " + i + ": ");
            int vacunas = int.Parse(Console.ReadLine());

            total += vacunas;
        }

        double promedio = total / 7.0;

        Console.WriteLine("Total de vacunas: " + total);
        Console.WriteLine("Promedio diario: " + promedio);
    }
}
